<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>中文生詞小老師 - Flashcards</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <style>
        .flip-card { perspective: 1000px; }
        .flip-card-inner {
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .is-flipped { transform: rotateY(180deg); }
        .flip-card-front, .flip-card-back {
            backface-visibility: hidden;
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
        }
        .flip-card-back { transform: rotateY(180deg); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen font-sans">

<div id="app" class="max-w-md mx-auto px-4 py-8">
    <header class="text-center mb-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">🏮 中文生詞練習</h1>
        <div class="flex items-center justify-between text-sm text-slate-500 bg-white p-3 rounded-xl shadow-sm">
            <span>進度：{{ currentIndex + 1 }} / {{ cards.length }}</span>
            <div class="w-32 bg-slate-200 h-2 rounded-full overflow-hidden">
                <div class="bg-blue-500 h-full transition-all duration-300" 
                     :style="{ width: ((currentIndex + 1) / cards.length * 100) + '%' }"></div>
            </div>
        </div>
    </header>

    <main v-if="!isFinished" class="flex flex-col items-center">
        <div class="flip-card w-full aspect-[3/4] cursor-pointer mb-8" @click="isFlipped = !isFlipped">
            <div class="flip-card-inner relative w-full h-full shadow-xl rounded-3xl" :class="{ 'is-flipped': isFlipped }">
                <div class="flip-card-front bg-white flex flex-col items-center justify-center p-8 border-4 border-blue-100 rounded-3xl">
                    <div class="text-6xl font-bold text-slate-800 mb-4">{{ currentCard.word }}</div>
                    <div class="text-xl text-blue-500 font-medium tracking-widest">{{ currentCard.pinyin }}</div>
                    <p class="mt-12 text-slate-300 text-sm">點擊翻面</p>
                </div>
                <div class="flip-card-back bg-blue-500 flex flex-col items-center justify-center p-8 rounded-3xl text-white">
                    <h2 class="text-sm uppercase tracking-widest opacity-80 mb-4">Meaning</h2>
                    <div class="text-3xl font-semibold text-center leading-relaxed">{{ currentCard.definition }}</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 w-full">
            <button @click="prevCard" :disabled="currentIndex === 0"
                    class="py-4 rounded-2xl font-bold transition bg-white text-slate-400 disabled:opacity-30 shadow-sm border border-slate-200 active:scale-95">
                上一個
            </button>
            <button @click="nextCard" 
                    class="py-4 rounded-2xl font-bold transition bg-blue-600 text-white shadow-lg shadow-blue-200 active:scale-95">
                {{ currentIndex === cards.length - 1 ? '完成' : '下一個' }}
            </button>
        </div>
    </main>

    <div v-else class="bg-white rounded-3xl p-10 text-center shadow-xl border border-slate-100">
        <div class="text-6xl mb-6">🎉</div>
        <h2 class="text-2xl font-bold text-slate-800 mb-2">做得好！</h2>
        <p class="text-slate-500 mb-8">你已經完成了本次的所有詞彙練習。</p>
        <button @click="resetGame" 
                class="w-full py-4 bg-emerald-500 text-white rounded-2xl font-bold shadow-lg shadow-emerald-100 active:scale-95">
            重新開始
        </button>
    </div>
</div>

<script>
    const { createApp, ref, computed } = Vue;

    createApp({
        setup() {
            // 💡 詞庫資料：老師可以在這裡直接新增或修改生詞
            const initialCards = [
                { word: '老師', pinyin: 'lǎo shī', definition: 'Teacher' },
                { word: '學生', pinyin: 'xué sheng', definition: 'Student' },
                { word: '學習', pinyin: 'xué xí', definition: 'To study / To learn' },
                { word: '漢字', pinyin: 'hàn zì', definition: 'Chinese Characters' },
                { word: '朋友', pinyin: 'péng you', definition: 'Friend' }
            ];

            const cards = ref([...initialCards]);
            const currentIndex = ref(0);
            const isFlipped = ref(false);
            const isFinished = ref(false);

            const currentCard = computed(() => cards.value[currentIndex.value]);

            const nextCard = () => {
                isFlipped.value = false;
                setTimeout(() => {
                    if (currentIndex.value < cards.value.length - 1) {
                        currentIndex.value++;
                    } else {
                        isFinished.value = true;
                    }
                }, 150);
            };

            const prevCard = () => {
                if (currentIndex.value > 0) {
                    isFlipped.value = false;
                    setTimeout(() => {
                        currentIndex.value--;
                    }, 150);
                }
            };

            const resetGame = () => {
                // 隨機打亂順序
                cards.value = [...initialCards].sort(() => Math.random() - 0.5);
                currentIndex.value = 0;
                isFlipped.value = false;
                isFinished.value = false;
            };

            // 初始化時打亂一次
            resetGame();

            return {
                cards, currentIndex, currentCard, isFlipped, isFinished,
                nextCard, prevCard, resetGame
            };
        }
    }).mount('#app');
</script>
</body>
